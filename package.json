{
  "name": "download-organizer",
  "version": "2.0.0",
  "type": "module",
  "bin": {
    "download-organizer": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && node --input-type=module -e \"import{writeFileSync,readFileSync}from'fs';const f='dist/index.js';writeFileSync(f,'#!/usr/bin/env node\\n'+readFileSync(f,'utf-8'))\"",
    "organize": "tsx src/index.ts organize",
    "watch": "tsx src/index.ts watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@types/node": "^25.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}